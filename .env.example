# CONFIGURACIÓN DE ENTORNO
NODE_ENV=development
PORT=4000

# Supabase (Vite solo expone variables con prefijo VITE_)
# Panel: Project Settings → API → Project URL y anon public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Configuración de la aplicación: FRONTEND (VITE)
VITE_APP_NAME=CobriXS
VITE_API_URL=http://localhost:5173